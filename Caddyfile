# Caddy reverse proxy for No True Man Show
# Replace {$DOMAIN} with your actual domain in .env, or use :80 for HTTP-only

{$DOMAIN:localhost} {
	# Renderer game
	reverse_proxy app:5173

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Gzip
	encode gzip
}
