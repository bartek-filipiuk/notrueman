# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=

# Brave Search API (free tier: 2000 queries/month)
# Get key at https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# TTS
TTS_BASE_URL=http://localhost:8880/v1
TTS_API_KEY=
TTS_MODEL=kokoro

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Database
DATABASE_URL=postgresql://truman:truman@localhost:5432/truman
POSTGRES_USER=truman
POSTGRES_PASSWORD=truman
POSTGRES_DB=truman

# Redis
REDIS_URL=redis://localhost:6379

# Streaming
RTMP_URL=rtmp://live.twitch.tv/app/YOUR_STREAM_KEY
STREAM_URL=http://host.docker.internal:5173
STREAM_RESOLUTION=960x540
STREAM_FRAMERATE=30
STREAM_VIDEO_BITRATE=4500k
STREAM_AUDIO_BITRATE=160k
BROWSER_RECYCLE_INTERVAL=14400
BROWSER_MAX_MEMORY_MB=2048

# Admin Panel
ADMIN_PASSWORD=
JWT_SECRET=

# Domain (for Caddy auto-HTTPS)
DOMAIN=localhost

# TTS toggle for streamer
TTS_ENABLED=off
TTS_VOICE=echo

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Observability
DISCORD_WEBHOOK_URL=

# Cost caps
DAILY_COST_CAP_USD=5.00
